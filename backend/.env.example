# Application
APP_NAME=Curriculum Orthogonality Checker
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/orthogonality
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/orthogonality

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# AI Model
MODEL_NAME=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.70

# FAISS
FAISS_INDEX_PATH=/app/data/faiss_index
